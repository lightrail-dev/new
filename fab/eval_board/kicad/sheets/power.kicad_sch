  ;; Stage 5: U12 TPS7A2010 LDO 1.8V → 1.0V (300mA) — FPGA VCCINT
  ;; Stage 6: U10 ADP7118 LDO 5V → 0.9V (150mA) — NCE VDD_CORE
  ;; ========================================================================

