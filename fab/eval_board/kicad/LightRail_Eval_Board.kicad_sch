  ;; Text annotation block
  (text "LightRail NCE+TFLN Evaluation Board\nPA-2026-001 Rev 1.0\n\nThis schematic defines the 100x100mm 22-layer eval board\nfor characterizing the SMIC 28nm NCE test chip (QFN-64)\nwith Artix-7 FPGA test controller and TFLN optical module.\n\nSee sub-sheets for detailed circuit implementation.\nSee fab/eval_board/ for complete 12-step design process docs."
    (at 20 80 0) (effects (font (size 2.54 2.54)))
