  (title_block
    (title "LightRail NCE+TFLN Evaluation Board")
    (date "2026-05-26")
    (rev "1.0")
    (company "LightRail AI")
    (comment 1 "Project: PA-2026-001")
    (comment 2 "100x100mm 22-Layer Intelligence Stack Eval Board")
    (comment 3 "NCE QFN-64 + Artix-7 FPGA + TFLN PIC")
    (comment 4 "SMIC 28nm HPC+ MPW Test Chip Characterization")
  )

  ;; ========================================================================
  ;; HIERARCHICAL SHEET STRUCTURE
  ;; This is the top-level schematic for the eval board.
  ;; Sub-sheets are defined below for each functional block.
  ;; ========================================================================

  ;; ---- Power Section ----
  ;; 12V Input (J1 barrel jack, J3 2-pin header)
  ;; F1 PTC fuse 2A
  ;; U15 TPS54360 Buck 12V→5V
  ;; U13 TPS7A3301 LDO 5V→3.3V
  ;; U11 TPS7A2018 LDO 3.3V→1.8V (NCE VDD_IO)
  ;; U14 TPS7A2018 LDO 3.3V→1.8V (FPGA VCCO)
  ;; U12 TPS7A2010 LDO 1.8V→1.0V (FPGA VCCINT)
  ;; U10 ADP7118 LDO 5V→0.9V (NCE VDD_CORE)
  ;; Power sequencing: 12V→5V→3.3V→1.8V→1.0V→0.9V

  ;; ---- NCE Test Chip (U1) ----
  ;; QFN-64, 8x8mm, 0.4mm pitch
  ;; VDD_CORE=0.9V, VDD_IO=1.8V
  ;; AXI4-Lite slave interface to FPGA
  ;; HBM5 emulation I/O
  ;; TFLN SerDes outputs
  ;; JTAG chain (TDI from FPGA TDO)

  ;; ---- FPGA (U2) ----
  ;; Xilinx Artix-7 XC7A100T-1FTG256C, BGA-256
  ;; VCCINT=1.0V, VCCAUX=3.3V, VCCO=1.8V
  ;; AXI4-Lite master to NCE
  ;; SPI master to Flash (U23)
  ;; UART to FT232H (U22)
  ;; GPIO expansion (J6)
  ;; JTAG chain (first in chain)

  ;; ---- TFLN PIC (U3) ----
  ;; Custom edge-coupler module
  ;; 8x TX RF drive from NCE SerDes (100Ω diff, AC-coupled)
  ;; 8x RX photodetector monitor to ADC (U21)
  ;; 8x DC bias from DAC (U24)
  ;; TEC control (TMP461 U25 + FPGA PWM)

  ;; ---- Clock Generation ----
  ;; Y1 100MHz TCXO → FPGA reference
  ;; U20 Si5395A PLL → 2.0GHz (CLK_HBM), 156.25MHz (TFLN SerDes ref)

  ;; ---- Test Interface ----
  ;; J2 USB-C → U22 FT232H → UART to FPGA
  ;; J5 JTAG 2x5 header → daisy chain: FPGA → NCE
  ;; J6 GPIO 2x7 header → FPGA I/O
  ;; J7-J10 SMA RF probe connectors
  ;; J11 MPO-24 fiber connector
  ;; SW1 Reset button
  ;; TP1-TP16 Test points

  ;; ---- Support ICs ----
  ;; U21 AD7928 ADC (TFLN PD monitor)
  ;; U22 FT232H USB-UART bridge
  ;; U23 W25Q128JVS SPI Flash (FPGA config)
  ;; U24 AD5684R DAC (TFLN bias)
  ;; U25 TMP461 Temp sensor (NCE die temp via I2C)

  ;; ========================================================================
  ;; NET CLASSES — 22-Layer Intelligence Stack (see .kicad_pro)
  ;; ========================================================================
  ;; Default:    0.15mm trace, 0.15mm clearance
  ;; AXI_BUS:    0.12mm trace, 0.12mm clearance, 50Ω SE — L10/L13
  ;; CLK_2GHZ:   0.08mm trace, 0.15mm clearance, 50Ω SE stripline — L4
  ;; TFLN_RF:    0.08mm trace, 100Ω diff, 0.10mm gap — L2 (TFLN Interconnect)
  ;; USB_HS:     0.09mm trace, 90Ω diff, 0.12mm gap — L20 (Framework)
  ;; PWR_5V:     1.00mm trace, 0.20mm clearance — L21 (PWR 3.3V/5V)
  ;; PWR_CORE:   0.50mm trace, 0.15mm clearance — L11/L17 (PWR 0.9V/1.0V/1.8V)
  ;; ========================================================================
  ;; GND Ref planes: L3, L6, L9, L12, L15, L18 (6 solid GND)
  ;; Power planes:   L11 (+0.9V), L17 (+1.0V/+1.8V), L21 (+3.3V/+5V)
  ;; Blind vias:     L1–L6 (top), L18–L22 (bottom)
  ;; Buried vias:    L6–L18 (core)
  ;; ========================================================================

