    (net 55 "GND"))

  ;; ── VIA-FREE KEEP-OUT ZONE (all layers, all items) ───────────────────────
  ;; Covers the full die body. Routing must fan out PAST the courtyard
  ;; before any via is placed.
  (zone (net 0) (net_name "")
    (layer "F.Cu") (tstamp "tfln-keepout-001")
    (connect_pads (clearance 0))
    (min_thickness 0.25)
    (keepout (tracks not_allowed) (vias not_allowed) (copperpour not_allowed)
             (footprints allowed) (text allowed))
    (polygon (pts
      (xy -12.5 -4.0) (xy 12.5 -4.0)
      (xy 12.5  4.0)  (xy -12.5  4.0)
    ))
  )
)
