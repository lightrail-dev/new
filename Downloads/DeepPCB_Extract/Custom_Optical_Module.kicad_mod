(footprint "Custom_Optical_Module" (version 20231014) (generator "pcbnew") (generator_version "9.0")
  (layer "F.Cu")
  (descr "TFLN PIC optical module — LightRail LR-TFLN-PIC-001. 25x8mm SMD. Pads 1-32 signal. Pads 33-40 GND shield.")
  (attr smd)

  ;; ── Silkscreen & Fab outline ──────────────────────────────────────────────
  (fp_text reference "REF**" (at 0 -5.5) (layer "F.SilkS")
    (effects (font (size 1 1) (thickness 0.15))))
  (fp_text value "TFLN_PIC" (at 0 5.5) (layer "F.Fab")
    (effects (font (size 1 1) (thickness 0.15))))

  ;; Body outline (25 × 8 mm)
  (fp_rect (start -12.5 -4.0) (end 12.5 4.0) (layer "F.Fab")
    (stroke (width 0.1) (type solid)) (fill none))
  ;; Courtyard (25.5 × 8.5 mm with 0.25 mm margin)
  (fp_rect (start -12.75 -4.25) (end 12.75 4.25) (layer "F.CrtYd")
    (stroke (width 0.05) (type solid)) (fill none))
  ;; Silkscreen — pin 1 marker
  (fp_line (start -12.75 -4.25) (end -11.75 -4.25) (layer "F.SilkS")
    (stroke (width 0.15) (type solid)))
  (fp_line (start -12.75 -4.25) (end -12.75 -3.25) (layer "F.SilkS")
    (stroke (width 0.15) (type solid)))

  ;; ── SIGNAL PADS 1–32 (pitch 0.625 mm, single row along centre-line) ───────
  ;; Left half: pads 1–20 (x from -12.188 to -0.312)
