  ;; ── GND SHIELD PADS 33–40 ────────────────────────────────────────────────
  ;; Four pads along each long edge (top/bottom of body), net GND.
  ;; These anchor the substrate GND plane to PCB GND via short vias.
  (pad "33" smd rect (at -8.0 -3.5) (size 1.2 0.8) (layers "F.Cu" "F.Paste" "F.Mask")
    (net 55 "GND"))
  (pad "34" smd rect (at -2.67 -3.5) (size 1.2 0.8) (layers "F.Cu" "F.Paste" "F.Mask")
