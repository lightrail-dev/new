  (pad "5"  smd rect (at  -9.688 0) (size 0.5 0.8) (layers "F.Cu" "F.Paste" "F.Mask"))
  (pad "6"  smd rect (at  -9.062 0) (size 0.5 0.8) (layers "F.Cu" "F.Paste" "F.Mask"))
  (pad "7"  smd rect (at  -8.438 0) (size 0.5 0.8) (layers "F.Cu" "F.Paste" "F.Mask"))
